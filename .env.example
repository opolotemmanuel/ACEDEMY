NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Use the real public origins for the deployed frontend/API.
ALLOWED_ORIGINS=https://academy.example.com

# Required in production. Use at least 32 random characters.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Python FastAPI service used for advisory AI insights and marking.
AI_SERVICE_URL=http://localhost:8000
AI_TIMEOUT_MS=2500

# Used only when the production data store is first initialized.
BOOTSTRAP_ADMIN_NAME=AQODH Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-temporary-admin-password
